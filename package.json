{
  "name": "studio-legale-lofoco",
  "version": "1.0.0",
  "description": "Studio Legale Lo Foco - Website",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "minify:css": "npx clean-css-cli -o style.min.css style.css",
    "minify:js": "npx terser script.js -o script.min.js --compress --mangle",
    "minify": "npm run minify:css && npm run minify:js",
    "optimize:images": "echo 'Use sips or imagemagick to optimize images'",
    "validate:html": "npx html-validate '*.html'",
    "lint:css": "npx stylelint '*.css'",
    "format": "npx prettier --write '*.{html,css,js,json,md}'",
    "build:html": "node scripts/build.js",
    "build": "npm run minify && npm run build:html -- --prod && echo 'Build complete! (production assets)'"
  },
  "keywords": [
    "law",
    "legal",
    "rome",
    "italy",
    "copyright",
    "cinema"
  ],
  "author": "Studio Legale Lo Foco",
  "license": "UNLICENSED",
  "devDependencies": {
    "clean-css-cli": "^5.6.2",
    "html-validate": "^8.7.4",
    "prettier": "^3.1.1",
    "stylelint": "^16.1.0",
    "terser": "^5.26.0"
  }
}
